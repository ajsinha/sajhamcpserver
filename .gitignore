# ============================================================================
# SAJHA MCP Server v3 — Git Ignore
# ============================================================================

# ── Database (SQLite files auto-created on startup, never checked in) ────
data/*.db
data/*.db-journal
data/*.db-wal
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────────────────────
logs/
*.log

# ── Temp ─────────────────────────────────────────────────────────────────
temp/
tmp/

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
.venv/
venv/
env/

# ── IDE ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# ── Environment (secrets) ───────────────────────────────────────────────
.env
.env.local
.env.production

# ── OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Alembic ──────────────────────────────────────────────────────────────
alembic/versions/*.pyc

# ── Test ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
