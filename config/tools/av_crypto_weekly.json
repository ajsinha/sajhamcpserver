{
  "name": "av_crypto_weekly",
  "implementation": "sajha.tools.impl.alphavantage_tools.AVCryptoWeeklyTool",
  "description": "Get weekly crypto prices from Alpha Vantage",
  "version": "4.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "default": "BTC"
      },
      "market": {
        "type": "string",
        "default": "USD"
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "Cryptocurrency",
    "tags": [
      "alphavantage",
      "crypto",
      "weekly"
    ]
  },
  "api_key": "${alpha_vantage.api.key}"
}