{
  "name": "yf_compare_stocks",
  "implementation": "sajha.tools.impl.yfinance_tools.YFCompareStocksTool",
  "description": "Compare multiple stocks from Yahoo Finance \u2014 side-by-side market cap, PE, dividend, 52-week range",
  "version": "3.1.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbols": {
        "type": "string",
        "description": "Comma-separated symbols (e.g., 'AAPL,MSFT,GOOGL')"
      }
    },
    "required": [
      "symbols"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
