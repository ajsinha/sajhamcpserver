{
  "name": "openbb_index_constituents",
  "implementation": "sajha.tools.impl.openbb_tools.OpenBBIndexConstituentsTool",
  "description": "Get index constituents via OpenBB \u2014 list of stocks in S&P 500, NASDAQ-100, Dow Jones, FTSE, etc.",
  "version": "3.1.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "index": {
        "type": "string",
        "description": "Index name (sp500, nasdaq, dowjones)",
        "default": "sp500"
      },
      "provider": {
        "type": "string",
        "description": "Data provider",
        "default": "yfinance"
      }
    },
    "required": [
      "index"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "Indexes",
    "tags": [
      "openbb",
      "index",
      "sp500",
      "nasdaq",
      "constituents"
    ],
    "examples": []
  }
}