{
  "name": "fmp_insider_trading",
  "implementation": "sajha.tools.impl.fmp_tools.FMPInsiderTradingTool",
  "description": "Get insider trading activity from FMP \u2014 buys, sells, and option exercises by company officers, directors, and major shareholders",
  "version": "4.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "description": "Stock ticker symbol (e.g., AAPL, MSFT, GOOGL)"
      },
      "limit": {
        "type": "integer",
        "description": "Number of transactions",
        "default": 20
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string"
      },
      "transactions_count": {
        "type": "integer"
      },
      "transactions": {
        "type": "array"
      }
    },
    "required": [
      "symbol",
      "transactions"
    ]
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "Ownership & Insider",
    "tags": [
      "fmp",
      "insider",
      "trading",
      "buy",
      "sell",
      "officers"
    ],
    "examples": [
      {
        "description": "Nvidia insider trades",
        "input": {
          "symbol": "NVDA",
          "limit": 20
        }
      }
    ]
  },
  "api_key": "${fmp.api.key}"
}