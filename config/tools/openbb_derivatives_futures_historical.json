{
  "name": "openbb_derivatives_futures_historical",
  "implementation": "sajha.tools.impl.openbb_tools.OpenBBGenericTool",
  "description": "Get historical futures prices via OpenBB",
  "version": "4.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "default": "CL=F"
      },
      "provider": {
        "type": "string",
        "default": "yfinance"
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "Derivatives",
    "tags": [
      "openbb",
      "futures",
      "historical"
    ]
  }
}