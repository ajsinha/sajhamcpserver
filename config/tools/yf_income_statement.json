{
  "name": "yf_income_statement",
  "implementation": "sajha.tools.impl.yfinance_tools.YFIncomeStatementTool",
  "description": "Get income statement from Yahoo Finance \u2014 revenue, net income, EPS (annual or quarterly)",
  "version": "4.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "description": "Stock ticker symbol (e.g., AAPL, MSFT)"
      },
      "quarterly": {
        "type": "boolean",
        "default": false
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "Financial Statements",
    "tags": [
      "yfinance",
      "income",
      "revenue"
    ]
  }
}