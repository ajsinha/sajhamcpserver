{
  "name": "cg_coin_info",
  "implementation": "sajha.tools.impl.coingecko_tools.CGCoinInfoTool",
  "description": "Get detailed crypto coin info from CoinGecko \u2014 description, links, categories, genesis date",
  "version": "3.1.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "default": "bitcoin"
      }
    },
    "required": [
      "id"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
