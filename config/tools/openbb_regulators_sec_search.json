{
  "name": "openbb_regulators_sec_search",
  "implementation": "sajha.tools.impl.openbb_tools.OpenBBGenericTool",
  "description": "Search SEC EDGAR via OpenBB \u2014 find companies and filings",
  "version": "3.1.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string"
      },
      "provider": {
        "type": "string",
        "default": "sec"
      }
    },
    "required": [
      "query"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
