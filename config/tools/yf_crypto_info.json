{
  "name": "yf_crypto_info",
  "implementation": "sajha.tools.impl.yfinance_tools.YFCryptoInfoTool",
  "description": "Get cryptocurrency info from Yahoo Finance \u2014 BTC, ETH, SOL price and market data",
  "version": "4.5.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "default": "BTC-USD"
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "Cryptocurrency",
    "tags": [
      "yfinance",
      "crypto"
    ]
  }
}