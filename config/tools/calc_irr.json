{
  "name": "calc_irr",
  "implementation": "sajha.tools.impl.calc_tools.CalcIRRTool",
  "description": "Calculate Internal Rate of Return (IRR) for a series of cash flows",
  "version": "4.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "cash_flows": {
        "type": "array",
        "items": {
          "type": "number"
        }
      }
    },
    "required": [
      "cash_flows"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
