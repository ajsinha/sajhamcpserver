{
  "name": "openbb_forex_historical",
  "implementation": "sajha.tools.impl.openbb_tools.OpenBBForexHistoricalTool",
  "description": "Get historical forex exchange rates via OpenBB \u2014 any currency pair (EURUSD, GBPJPY, etc.) with daily OHLCV data",
  "version": "4.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "description": "Currency pair (e.g., EURUSD, GBPJPY, USDINR)",
        "default": "EURUSD"
      },
      "start_date": {
        "type": "string",
        "description": "Start date (YYYY-MM-DD)",
        "format": "date"
      },
      "end_date": {
        "type": "string",
        "description": "End date (YYYY-MM-DD)",
        "format": "date"
      },
      "provider": {
        "type": "string",
        "description": "Data provider",
        "default": "yfinance"
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string"
      },
      "data_points": {
        "type": "integer"
      },
      "rates": {
        "type": "array"
      }
    },
    "required": [
      "symbol",
      "rates"
    ]
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "Forex",
    "tags": [
      "openbb",
      "forex",
      "currency",
      "exchange rate",
      "fx"
    ],
    "examples": [
      {
        "description": "EUR/USD 3 months",
        "input": {
          "symbol": "EURUSD",
          "start_date": "2026-02-01"
        }
      },
      {
        "description": "USD/INR 6 months",
        "input": {
          "symbol": "USDINR",
          "start_date": "2025-11-01"
        }
      }
    ]
  }
}