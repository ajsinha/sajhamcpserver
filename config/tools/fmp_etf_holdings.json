{
  "name": "fmp_etf_holdings",
  "implementation": "sajha.tools.impl.fmp_tools.FMPETFHoldingsTool",
  "description": "Get ETF holdings from FMP \u2014 constituent stocks, weights, shares held for any ETF (SPY, QQQ, IWM, etc.)",
  "version": "4.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "description": "Stock ticker symbol (e.g., AAPL, MSFT)"
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "ETFs",
    "tags": [
      "fmp",
      "etf",
      "holdings",
      "constituents",
      "portfolio"
    ],
    "examples": []
  },
  "api_key": "${fmp.api.key}"
}