{
  "name": "yf_stock_info",
  "implementation": "sajha.tools.impl.yfinance_tools.YFStockInfoTool",
  "description": "Get comprehensive stock info from Yahoo Finance \u2014 price, market cap, sector, PE, dividend, 52-week range, analyst targets",
  "version": "3.1.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "description": "Stock ticker symbol (e.g., AAPL, MSFT)"
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
