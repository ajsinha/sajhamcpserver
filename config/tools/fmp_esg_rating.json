{
  "name": "fmp_esg_rating",
  "implementation": "sajha.tools.impl.fmp_tools.FMPGenericTool",
  "description": "Get ESG rating from FMP \u2014 environmental, social, governance scores",
  "version": "4.5.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "description": "Stock ticker symbol"
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
  "metadata": {
    "author": "Ashutosh Sinha",
    "email": "ajsinha@gmail.com",
    "copyright": "Copyright All rights Reserved 2025-2030, Ashutosh Sinha",
    "category": "ESG",
    "tags": [
      "fmp",
      "esg",
      "rating"
    ]
  },
  "api_key": "${fmp.api.key}"
}