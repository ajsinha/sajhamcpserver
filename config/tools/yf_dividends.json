{
  "name": "yf_dividends",
  "implementation": "sajha.tools.impl.yfinance_tools.YFDividendsTool",
  "description": "Get dividend history from Yahoo Finance \u2014 all historical dividend payments with dates and amounts",
  "version": "4.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "symbol": {
        "type": "string",
        "description": "Stock ticker symbol (e.g., AAPL, MSFT)"
      }
    },
    "required": [
      "symbol"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "object"
      }
    }
  },
